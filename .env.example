# Hermes 原生 OpenAI-compatible API Server 地址，只允许本机 loopback。
STEPBEAST_HERMES_URL=http://127.0.0.1:8642

# 与 Hermes API_SERVER_KEY 使用相同值。请复制为 .env 后填写，禁止提交真实密钥。
STEPBEAST_HERMES_API_KEY=

# Obsidian Vault 根目录。StepBeast 只读 Markdown，不读取 .obsidian、.trash 等程序目录。
STEPBEAST_OBSIDIAN_VAULT_PATH=E:/path/to/your/ObsidianVault

# 带 type: project_index 的项目总览，相对于 Vault 根目录。
STEPBEAST_OBSIDIAN_PROJECT_INDEX_PATH=02 项目/项目总览.md
